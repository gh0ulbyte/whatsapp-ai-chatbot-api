PORT=8000

# Meta WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAB...
WHATSAPP_API_VERSION=v21.0

# Webhook verification (Meta dashboard -> Webhooks)
WEBHOOK_VERIFY_TOKEN=change-me

# Optional: validate webhook signatures (recommended in production)
# Uses header: X-Hub-Signature-256: sha256=<hexdigest>
META_APP_SECRET=
